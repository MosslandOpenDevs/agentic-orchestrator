datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model Portfolio {
  id String @id @default(uuid())
  userId String
  riskTolerance Float
  createdAt DateTime @default(now())
  @@index([userId])
}

model Transaction {
  id String @id @default(uuid())
  portfolioId String
  timestamp DateTime
  asset String
  quantity Float
  price Float
  @@index([portfolioId])
  @@relation "transactions" [Portfolio]
}

model RaveBlockchainData {
  id String @id @default(uuid())
  timestamp DateTime
  event String
  data Json
  @@index([timestamp])
}

model MarketIndicator {
  id String @id @default(uuid())
  timestamp DateTime
  indicatorType String
  value Float
  @@index([timestamp])
}