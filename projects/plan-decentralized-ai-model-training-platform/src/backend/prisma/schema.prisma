generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id String @id @default(uuid())
  address String
  createdAt DateTime @default(now())
}

model Model {
  id String @id @default(uuid())
  name String
  description String
  nvcModelId String
  createdAt DateTime @default(now())
}

model Transaction {
  id String @id @default(uuid())
  timestamp DateTime
  modelId String
  userId String
  amount uint256
  createdAt DateTime @default(now())
  
  model {
    id String
    name String
    description String
    nvcModelId String
    createdAt DateTime
  }
  user {
    id String
    address String
    createdAt DateTime
  }
}