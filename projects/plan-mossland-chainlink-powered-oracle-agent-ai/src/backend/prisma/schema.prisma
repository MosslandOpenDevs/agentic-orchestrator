datasource db {
  provider = postgres
  url = env("DATABASE_URL")
  shards = true
}

model Portfolio {
  id String @id @default(uuid())
  userId String
  riskProfile String
  returnTarget Float
  createdAt DateTime @default(now())
  @relation(fields: [userId], references: [id])
  User User
}

model Asset {
  id String @id @default(uuid())
  portfolioId String
  assetType String
  quantity Float
  assetPrice Float
  assetDetails JSON
  @relation(fields: [portfolioId], references: [id])
  Portfolio Portfolio
}

model ChainlinkDataFeed {
  id String @id @default(uuid())
  assetType String
  data Float
  lastUpdated DateTime @default(now())
}

model GPT5Strategy {
  id String @id @default(uuid())
  strategyName String
  strategyDescription String
  assetAllocation JSON
}

model User {
  id String @id @default(uuid())
  name String
  email String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}