# =============================================================================
# Mossland Agentic Orchestrator - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# -----------------------------------------------------------------------------
# LLM API Keys
# -----------------------------------------------------------------------------

# Anthropic API Key (for Claude API direct calls)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI API Key (for GPT models - review/evaluation)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxx

# Google Gemini API Key (for Gemini models - review/evaluation)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyxxxxx

# -----------------------------------------------------------------------------
# Local LLM (Ollama) — REQUIRED for debate / planning workers
# -----------------------------------------------------------------------------

# Host URL of the Ollama server. Required by the PM2 schedulers
# (debate / trends / backlog) and by ContentTranslator. Without this,
# OllamaProvider falls back to http://localhost:11434, which is almost
# never what you want in production — every model call will return 404
# and the planning phase will produce empty plans.
#
# ecosystem.config.js parses this file directly, so just setting the
# variable here is enough — no need to also export it in your shell.
OLLAMA_HOST=http://localhost:11434

# -----------------------------------------------------------------------------
# GitHub Configuration (REQUIRED for backlog workflow)
# -----------------------------------------------------------------------------

# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
# Required scopes: repo (full control - for Issues and Labels)
GITHUB_TOKEN=ghp_xxxxx

# Repository information
GITHUB_OWNER=mossland
GITHUB_REPO=agentic-orchestrator

# Git user configuration (for commits)
GIT_USER_NAME=Agentic Orchestrator
GIT_USER_EMAIL=orchestrator@mossland.org

# -----------------------------------------------------------------------------
# Orchestrator Configuration
# -----------------------------------------------------------------------------

# Default Claude model for development tasks
# Options: opus, sonnet (opus recommended for complex tasks)
CLAUDE_MODEL=opus

# OpenAI model for review/evaluation
# Default: gpt-5.2-chat-latest (latest), Fallback: gpt-5.2
OPENAI_MODEL=gpt-5.2-chat-latest
OPENAI_MODEL_FALLBACK=gpt-5.2

# Gemini model for review/evaluation
# Default: gemini-3-flash-preview (fast), Fallback: gemini-3-pro-preview
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_MODEL_FALLBACK=gemini-3-pro-preview

# Pinned model versions for reproducibility (optional)
# Set these to use specific model versions instead of latest
# OPENAI_MODEL_PINNED=gpt-5.2-0601
# GEMINI_MODEL_PINNED=gemini-3-flash-001

# -----------------------------------------------------------------------------
# Execution Limits
# -----------------------------------------------------------------------------

# Maximum planning iterations before escalation
PLANNING_MAX_ITERATIONS=3

# Maximum development iterations before escalation
DEV_MAX_ITERATIONS=5

# Rate limit retry settings
RATE_LIMIT_MAX_RETRIES=5
RATE_LIMIT_MAX_WAIT_SECONDS=3600

# Loop mode settings
LOOP_MAX_STEPS=100
LOOP_DELAY_SECONDS=10

# -----------------------------------------------------------------------------
# Backlog Workflow Settings
# -----------------------------------------------------------------------------

# Number of ideas to generate per run
IDEA_GENERATION_COUNT=1

# Maximum promotions to process per run
MAX_PROMOTIONS_PER_RUN=5

# -----------------------------------------------------------------------------
# Dry Run Mode
# -----------------------------------------------------------------------------

# Set to 'true' to run without making actual API calls
# Useful for testing the orchestrator logic
DRY_RUN=false

# -----------------------------------------------------------------------------
# API Server Security
# -----------------------------------------------------------------------------

# Required: shared secret for mutating endpoints (X-API-Key header).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Without this set, /plans/{id}/approve and /plans/{id}/generate-project
# return 503 Service Unavailable.
MOSS_API_KEY=

# Comma-separated CORS origins allowed to call the API.
# Default: https://ao.moss.land,http://localhost:3000,http://127.0.0.1:3000
# MOSS_CORS_ORIGINS=https://ao.moss.land,http://localhost:3000
